# Copy this file to .env.test and fill in real values.
# .env.test is git-ignored — never commit real credentials.

BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/school_nexus_test
API_SECRET=<your_test_api_secret>
ADMIN_EMAIL=<admin_email>
ADMIN_PASSWORD=<admin_password>
TEACHER_EMAIL=<teacher_email>
TEACHER_PASSWORD=<teacher_password>
STUDENT_EMAIL=<student_email>
STUDENT_PASSWORD=<student_password>
